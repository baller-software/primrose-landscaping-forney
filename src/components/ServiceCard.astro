---
interface Props {
  name: string;
  description: string;
  icon: string;
}

const { name, description, icon } = Astro.props;
---

<div class="rounded-lg border border-border p-8">
  <div class="mb-4 text-4xl" aria-hidden="true">{icon}</div>
  <h2 class="text-h2 font-semibold text-text-primary">{name}</h2>
  <p class="mt-3 leading-relaxed text-text-secondary">{description}</p>
</div>
