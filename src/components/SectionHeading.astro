---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-10 text-center">
  <h2 class="text-h2 font-semibold text-text-primary">{title}</h2>
  {
    subtitle && (
      <p class="mx-auto mt-3 max-w-2xl text-body-lg text-text-secondary">
        {subtitle}
      </p>
    )
  }
</div>
