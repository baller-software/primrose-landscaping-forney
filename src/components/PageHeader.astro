---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="bg-slate-dark px-4 py-16 lg:py-20">
  <div class="mx-auto max-w-[1152px]">
    <h1 class="text-4xl font-bold text-white sm:text-5xl">{title}</h1>
    {
      subtitle && (
        <p class="mt-4 max-w-2xl text-body-lg text-slate-300">{subtitle}</p>
      )
    }
  </div>
</section>
