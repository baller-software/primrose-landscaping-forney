---
import { site } from '../data/site';

interface Props {
  endpoint?: string;
}

const { endpoint = site.formspreeEndpoint } = Astro.props;
---

<form
  id="contact-form"
  action={endpoint}
  method="POST"
  class="space-y-6"
  novalidate
>
  <!-- Name -->
  <div>
    <label
      for="contact-name"
      class="block text-sm font-medium text-text-primary"
    >
      Name <span class="text-error">*</span>
    </label>
    <input
      type="text"
      id="contact-name"
      name="name"
      required
      autocomplete="name"
      class="mt-1 block w-full rounded-md border border-border bg-transparent px-4 py-3 text-text-primary transition-colors duration-fast placeholder:text-text-disabled focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"
      placeholder="Your name"
    />
    <p class="mt-1 hidden text-sm text-error" data-error="name">
      Please enter your name.
    </p>
  </div>

  <!-- Email -->
  <div>
    <label
      for="contact-email"
      class="block text-sm font-medium text-text-primary"
    >
      Email <span class="text-error">*</span>
    </label>
    <input
      type="email"
      id="contact-email"
      name="email"
      required
      autocomplete="email"
      class="mt-1 block w-full rounded-md border border-border bg-transparent px-4 py-3 text-text-primary transition-colors duration-fast placeholder:text-text-disabled focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"
      placeholder="you@example.com"
    />
    <p class="mt-1 hidden text-sm text-error" data-error="email">
      Please enter a valid email address.
    </p>
  </div>

  <!-- Phone (optional) -->
  <div>
    <label
      for="contact-phone"
      class="block text-sm font-medium text-text-primary"
    >
      Phone <span class="text-text-disabled">(optional)</span>
    </label>
    <input
      type="tel"
      id="contact-phone"
      name="phone"
      autocomplete="tel"
      class="mt-1 block w-full rounded-md border border-border bg-transparent px-4 py-3 text-text-primary transition-colors duration-fast placeholder:text-text-disabled focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"
      placeholder="(555) 123-4567"
    />
  </div>

  <!-- Message -->
  <div>
    <label
      for="contact-message"
      class="block text-sm font-medium text-text-primary"
    >
      Message <span class="text-error">*</span>
    </label>
    <textarea
      id="contact-message"
      name="message"
      required
      rows="5"
      class="mt-1 block w-full rounded-md border border-border bg-transparent px-4 py-3 text-text-primary transition-colors duration-fast placeholder:text-text-disabled focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"
      placeholder="Tell us about your project or question..."></textarea>
    <p class="mt-1 hidden text-sm text-error" data-error="message">
      Please enter a message.
    </p>
  </div>

  <!-- Honeypot (hidden from humans) -->
  <div class="absolute -left-[9999px]" aria-hidden="true">
    <label for="contact-gotcha">Do not fill this out</label>
    <input
      type="text"
      id="contact-gotcha"
      name="_gotcha"
      tabindex="-1"
      autocomplete="off"
    />
  </div>

  <!-- Submit -->
  <button
    type="submit"
    id="contact-submit"
    class="inline-flex h-12 w-full items-center justify-center rounded-md bg-primary px-6 text-sm font-semibold text-white transition-colors duration-fast hover:bg-primary-dark focus:ring-2 focus:ring-primary/20 focus:ring-offset-2 focus:outline-none disabled:cursor-not-allowed disabled:opacity-50 sm:w-auto"
  >
    Send Message
  </button>
</form>

<!-- Success message (hidden by default) -->
<div
  id="contact-success"
  class="hidden rounded-lg border border-success/30 bg-success/10 p-6 text-center"
>
  <svg
    class="mx-auto h-12 w-12 text-success"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="1.5"
    stroke="currentColor"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
  </svg>
  <h3 class="mt-4 text-lg font-semibold text-text-primary">Thank you!</h3>
  <p class="mt-2 text-text-secondary">
    We've received your message and will get back to you soon.
  </p>
</div>

<!-- Error message (hidden by default) -->
<div
  id="contact-error"
  class="hidden rounded-lg border border-error/30 bg-error/10 p-6 text-center"
>
  <p class="font-medium text-error">
    Something went wrong. Please try again or contact us by phone at {
      site.phone
    }.
  </p>
</div>

<script>
  const form = document.getElementById(
    'contact-form',
  ) as HTMLFormElement | null;
  const submitBtn = document.getElementById(
    'contact-submit',
  ) as HTMLButtonElement | null;
  const successEl = document.getElementById('contact-success');
  const errorEl = document.getElementById('contact-error');

  if (form && submitBtn && successEl && errorEl) {
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    function showError(field: string) {
      const el = form!.querySelector(
        `[data-error="${field}"]`,
      ) as HTMLElement | null;
      if (el) el.classList.remove('hidden');
    }

    function clearErrors() {
      form!.querySelectorAll('[data-error]').forEach((el) => {
        el.classList.add('hidden');
      });
    }

    function validate(): boolean {
      clearErrors();
      let valid = true;

      const name = (
        form!.querySelector('[name="name"]') as HTMLInputElement
      ).value.trim();
      const email = (
        form!.querySelector('[name="email"]') as HTMLInputElement
      ).value.trim();
      const message = (
        form!.querySelector('[name="message"]') as HTMLTextAreaElement
      ).value.trim();

      if (!name) {
        showError('name');
        valid = false;
      }
      if (!email || !emailRegex.test(email)) {
        showError('email');
        valid = false;
      }
      if (!message) {
        showError('message');
        valid = false;
      }

      return valid;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!validate()) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      errorEl.classList.add('hidden');

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (response.ok) {
          form.classList.add('hidden');
          successEl.classList.remove('hidden');
        } else {
          errorEl.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Message';
        }
      } catch {
        errorEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
      }
    });
  }
</script>
