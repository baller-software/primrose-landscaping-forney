---
interface Props {
  heading: string;
  description: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  heading,
  description,
  buttonText = 'Contact Us',
  buttonHref = '/contact/',
} = Astro.props;
---

<section class="bg-primary px-4 py-16 lg:py-20">
  <div class="mx-auto max-w-[1152px] text-center">
    <h2 class="text-3xl font-bold text-white sm:text-4xl">{heading}</h2>
    <p class="mx-auto mt-4 max-w-xl text-body-lg text-primary-light">
      {description}
    </p>
    <a
      href={buttonHref}
      class="mt-8 inline-flex h-12 items-center justify-center rounded-md border-2 border-white bg-white px-8 text-sm font-semibold text-primary transition-colors duration-fast hover:bg-transparent hover:text-white"
    >
      {buttonText}
    </a>
  </div>
</section>
