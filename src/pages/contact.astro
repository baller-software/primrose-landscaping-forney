---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactInfo from '../components/ContactInfo.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with Primrose Landscaping in Forney, TX. Call, email, or send us a message for a free consultation."
>
  <PageHeader
    title="Contact Us"
    subtitle="We'd love to hear from you. Reach out for a free consultation or to learn more about our services."
  />

  <section class="px-4 py-16 lg:py-20">
    <div class="mx-auto grid max-w-[1152px] gap-12 lg:grid-cols-2">
      <!-- Contact info -->
      <div>
        <h2 class="text-h2 font-semibold text-text-primary">Get in Touch</h2>
        <p class="mt-3 mb-8 text-text-secondary">
          Whether you have a question about our services, want a free estimate,
          or just want to say hello — we're here for you.
        </p>
        <ContactInfo />
      </div>

      <!-- Contact form -->
      <div>
        <h2 class="text-h2 font-semibold text-text-primary">
          Send Us a Message
        </h2>
        <p class="mt-3 mb-8 text-text-secondary">
          Fill out the form below and we'll get back to you as soon as possible.
        </p>
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>
