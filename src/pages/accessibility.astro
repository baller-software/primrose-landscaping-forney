---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Accessibility"
  description="Accessibility statement for Primrose Landscaping."
>
  <section class="px-4 py-16">
    <div class="prose mx-auto max-w-[1152px]">
      <h1>Accessibility Statement</h1>
      <p>
        Primrose Landscaping is committed to ensuring our website is accessible
        to all visitors. We strive to meet WCAG 2.1 AA standards. If you
        experience any difficulty accessing our site, please contact us and we
        will be happy to assist.
      </p>
    </div>
  </section>
</BaseLayout>
